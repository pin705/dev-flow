{
  "name": "devflow",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.2.21",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "npm --prefix apps/web run dev",
    "dev:cli": "npm --prefix apps/cli run dev",
    "build": "npm run build:web",
    "build:web": "npm --prefix apps/web run build",
    "build:vscode": "npm --prefix apps/vscode run build",
    "start": "npm run start:web",
    "start:web": "npm --prefix apps/web run start",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix . && npm run format",
    "lint:strict": "oxlint --deny-warnings .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "typecheck": "npx tsc -p apps/web/tsconfig.json --noEmit",
    "docs:check": "npm --prefix apps/web run docs:check",
    "check": "npm run typecheck && npm run docs:check",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "tsx": "^4.19.2",
    "typescript": "5.7.2"
  },
  "overrides": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  },
  "lint-staged": {
    "!(scripts)/**/*.{js,jsx,tsx,ts,css,less,scss,sass,md,mdx,json}": [
      "oxfmt --write"
    ]
  }
}
